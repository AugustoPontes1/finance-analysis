# Dev enviroment
SECRET_KEY=
DEBUG=
ALLOWED_HOSTS=
DJANGO_APP_PORT=

SEAWEEDFS_MASTER_URL=
SEAWEEDFS_VOLUME_URL=
API_BASE=

DB_ENGINE=
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_HOST=
DB_PORT=

LLM_PROVIDER=local  # → uses LocalLLMService (talks to your Ollama docker container):
LLM_MODEL_URL=http://localhost:11434/api/generate# — the Ollama generate endpoint, e.g. http://localhost:11434/api/generate
LLM_MODEL_NAME=llama3 # — the model to run, e.g. llama3

# LLM_PROVIDER=<anything else> → uses RemoteLLMService (OpenAI-compatible API or Claude):
# LLM_REMOTE_URL — the remote API endpoint
# LLM_REMOTE_API_KEY — the API key
# LLM_REMOTE_MODEL — the model name, e.g. gpt-4o or claude-sonnet-4-6

# OLLAMA_NUM_PARALLEL=1
# OLLAMA_MAX_LOADED_MODELS=1

